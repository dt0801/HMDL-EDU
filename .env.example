# Supabase (lấy từ output của `supabase start` hoặc Supabase Cloud Dashboard)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Service role key — CHỈ dùng trong server-side code, KHÔNG expose ra client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# URL public của ứng dụng
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Zoom Server-to-Server OAuth
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_HOST_USER_ID=

# Certificate Generator server-side render/storage
CERTIFICATE_RENDER_MODE=server
CERTIFICATE_STORAGE_PROVIDER=cloudinary
BROWSERLESS_WS_ENDPOINT=
BROWSERLESS_TOKEN=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=hmdl-edu/certificates
