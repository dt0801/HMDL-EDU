# Supabase (lấy từ output của `supabase start` hoặc Supabase Cloud Dashboard)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Service role key — CHỈ dùng trong server-side code, KHÔNG expose ra client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# URL public của ứng dụng
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Zoom Server-to-Server OAuth
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_HOST_USER_ID=
